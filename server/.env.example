# Local values for these mirror what's resolved from SSM Parameter Store in production —
# see docs/aws-infrastructure.md ("Environment variables > Lambda — stored in SSM
# Parameter Store") for the exact SSM paths and which of these are SecureString.

# --- SecureString in SSM (real secrets) ---
MONGODB_URI=                # Atlas connection string (srv:// format)
JWT_SECRET=                  # Signs/verifies the API's own access tokens (see docs/auth.md)
RECAPTCHA_SECRET=            # Google reCAPTCHA v3 secret key

# --- Plain String in SSM (not secrets) ---
SES_FROM_EMAIL=              # Verified SES sending address
ADMIN_ALERT_EMAIL=           # Editor notification address
CLOUDFRONT_DIST_ID=          # CloudFront distribution ID
S3_BUCKET_NAME=              # Media upload bucket name
CF_DOMAIN=                   # CloudFront domain e.g. d1abc.cloudfront.net
DYNAMO_DEDUP_TABLE=          # DynamoDB table name: view_dedup
DYNAMO_RATELIMIT_TABLE=      # DynamoDB table name: ratelimit
DYNAMO_REFRESH_TABLE=        # DynamoDB table name: refresh_tokens (auth refresh-token store)
API_BASE_URL=                # This API's own public API Gateway URL (or http://localhost:3001 locally)
FRONTEND_URL=                # Public frontend URL (same value as NEXTAUTH_URL in web/.env.local)

# --- Not SSM-resolved; also needed at runtime ---
AWS_REGION=                  # e.g. af-south-1 (Africa — Lagos) or us-east-1