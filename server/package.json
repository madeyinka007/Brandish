{
  "name": "brandish-server",
  "version": "0.1.0",
  "private": true,
  "description": "Brandish Express API — deployed as a single AWS Lambda function via serverless-http",
  "main": "index.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "seed:admin": "ts-node scripts/seedSuperAdmin.ts",
    "seed:categories": "ts-node scripts/seedCategories.ts",
    "seed:comments": "ts-node scripts/seedComments.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.622.0",
    "@aws-sdk/client-dynamodb": "^3.622.0",
    "@aws-sdk/client-s3": "^3.622.0",
    "@aws-sdk/client-ses": "^3.622.0",
    "@aws-sdk/s3-request-presigner": "^3.622.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.8.0",
    "mongoose": "^8.5.0",
    "next-auth": "^4.24.7",
    "sanitize-html": "^2.13.0",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/sanitize-html": "^2.13.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
